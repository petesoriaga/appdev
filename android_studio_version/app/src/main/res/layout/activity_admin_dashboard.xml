<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Admin Dashboard" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/primary"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAllReservations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"/>
</LinearLayout>
